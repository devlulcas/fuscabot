{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client", "@types/react", "@types/react-dom"],
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["src/**/*_test.ts"]
}
