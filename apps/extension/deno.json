{
  "tasks": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "test:ui": "node ../../node_modules/vitest/vitest.mjs run",
    "check": "deno fmt --check && deno lint && deno check src/*.ts src/**/*.ts vite.config.ts && deno run -A npm:typescript@7.0.2/tsc --noEmit -p tsconfig.json && deno test && deno task test:ui && deno task build"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@tanstack/react-query": "npm:@tanstack/react-query@5",
    "@tanstack/react-query-persist-client": "npm:@tanstack/react-query-persist-client@5",
    "@tanstack/query-persist-client-core": "npm:@tanstack/query-persist-client-core@5",
    "@testing-library/jest-dom": "npm:@testing-library/jest-dom@6",
    "@testing-library/react": "npm:@testing-library/react@16",
    "@testing-library/user-event": "npm:@testing-library/user-event@14",
    "@types/react": "npm:@types/react@19",
    "@types/react-dom": "npm:@types/react-dom@19",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@5",
    "axe-core": "npm:axe-core@4",
    "jsdom": "npm:jsdom@27",
    "react": "npm:react@19",
    "react/jsx-runtime": "npm:react@19/jsx-runtime",
    "react-dom": "npm:react-dom@19",
    "react-dom/client": "npm:react-dom@19/client",
    "react-router-dom": "npm:react-router-dom@7",
    "vite": "npm:vite@7",
    "vitest": "npm:vitest@4",
    "vitest/config": "npm:vitest@4/config",
    "typescript": "npm:typescript@7.0.2",
    "zod": "npm:zod@4.4.3"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["@types/react", "@types/react-dom", "vite/client"]
  },
  "fmt": { "exclude": ["dist"] },
  "lint": { "exclude": ["dist"] },
  "exclude": ["dist"]
}
