{
  "tasks": {
    "build": "deno run --allow-read=src,manifest.json,../../../packages/contracts --allow-write=dist --allow-run scripts/build.ts",
    "check": "deno fmt --check && deno lint && deno check src/*.ts src/**/*.ts scripts/*.ts && deno test"
  },
  "imports": { "@std/assert": "jsr:@std/assert@1" },
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "fmt": { "exclude": ["dist"] },
  "lint": { "exclude": ["dist"] },
  "exclude": ["dist"]
}
