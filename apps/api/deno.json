{
  "deploy": {
    "org": "devlulcas",
    "app": "fuscabot",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./main.ts",
      "cwd": "."
    },
    "predeploy": "deno task migrate"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.8.3",
    "@fuscabot/contracts": "../../packages/contracts/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@tanstack/ai": "npm:@tanstack/ai@0.41.0",
    "@tanstack/ai-mistral": "npm:@tanstack/ai-mistral@0.2.2",
    "drizzle-kit": "npm:drizzle-kit@0.31.4",
    "drizzle-orm": "npm:drizzle-orm@^0.44.2",
    "drizzle-orm/node-postgres/migrator": "npm:drizzle-orm@^0.44.2/node-postgres/migrator",
    "drizzle-orm/pg-core": "npm:drizzle-orm@^0.44.2/pg-core",
    "pg": "npm:pg@^8.16.3",
    "@types/pg": "npm:@types/pg@^8.15.5",
    "zod": "jsr:@zod/zod@4"
  },
  "tasks": {
    "dev": "deno run --watch --allow-env --allow-net src/server.ts",
    "start": "deno run --allow-env --allow-net src/server.ts",
    "check": "deno check main.ts src/server.ts src/db/schema.ts",
    "db:generate": "deno run -A npm:drizzle-kit@0.31.4 generate --config=drizzle.config.ts",
    "db:check": "deno run -A npm:drizzle-kit@0.31.4 check --config=drizzle.config.ts",
    "migrate": "deno run --allow-env --allow-net --allow-read=drizzle src/db/migrate.ts",
    "test": "deno test --allow-env"
  },
  "fmt": { "lineWidth": 100 },
  "lint": { "rules": { "tags": ["recommended"] } }
}
