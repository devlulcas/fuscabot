{
  "workspace": [
    "./apps/api",
    "./apps/extension",
    "./apps/web",
    "./packages/contracts"
  ],
  "nodeModulesDir": "auto",
  "deploy": {
    "org": "devlulcas",
    "app": "fuscabot",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./apps/api/main.ts",
      "cwd": "."
    },
    "predeploy": "deno task migrate"
  },
  "tasks": {
    "check": "deno task fmt:check && deno task lint && deno task typecheck && deno task test",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "typecheck": "deno check apps/api/src/server.ts apps/web/mod.ts packages/contracts/mod.ts && deno task --cwd apps/extension check",
    "test": "deno test -A",
    "dev:api": "deno task --cwd apps/api dev",
    "build:extension": "deno task --cwd apps/extension build",
    "db:migrate": "deno task --cwd apps/api migrate",
    "migrate": "deno task --cwd apps/api migrate"
  },
  "fmt": {
    "exclude": [
      "apps/extension/dist/"
    ]
  },
  "lint": {
    "exclude": ["apps/extension/dist/"]
  },
  "exclude": ["apps/extension/dist/"]
}
