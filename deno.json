{
  "workspace": [
    "./apps/api",
    "./apps/extension",
    "./apps/web",
    "./packages/contracts"
  ],
  "nodeModulesDir": "auto",
  "deploy": {
    "org": "devlulcas",
    "app": "fuscabot",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "./apps/api/main.ts",
      "cwd": "."
    },
    "predeploy": "deno task predeploy"
  },
  "tasks": {
    "check": "deno task build:web && deno task fmt:check && deno task lint && deno task typecheck && deno task test",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "typecheck": "deno check apps/api/src/server.ts apps/web/mod.ts packages/contracts/mod.ts && deno task --cwd apps/extension check",
    "test": "deno test -A",
    "dev:api": "deno task --cwd apps/api dev",
    "build:extension": "deno task --cwd apps/extension build",
    "build:web": "deno task --cwd apps/web build",
    "db:generate": "deno task --cwd apps/api db:generate",
    "db:check": "deno task --cwd apps/api db:check",
    "db:migrate": "deno task --cwd apps/api migrate",
    "migrate": "deno task --cwd apps/api migrate",
    "predeploy": "deno task build:web && deno task migrate"
  },
  "fmt": {
    "exclude": [
      "apps/extension/dist/",
      "apps/web/src/client.bundle.js"
    ]
  },
  "lint": {
    "exclude": ["apps/extension/dist/", "apps/web/src/client.bundle.js"]
  },
  "exclude": ["apps/extension/dist/", "apps/web/src/client.bundle.js"]
}
